```
# ArgoCD specific ignores
argocd-structure/secrets/**
!argocd-structure/secrets/README.md

# Kubernetes manifests backup/config
*.bak
*.backup
*.orig

# General ignores for ArgoCD projects
*.log
*.tmp
*.swp
*~
.DS_Store
Thumbs.db

# Environment files
.env
.env.local
.env.*

# IDE files
.vscode/
.idea/
*.iml
*.ipr
*.iws

# Build outputs (if any)
dist/
build/
target/
_coverage/

# Python (if used in automation)
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so
.coverage
htmlcov/
.pytest_cache/
.mypy_cache/

# Node (if used in UI components)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Temporary files
*.tmp
*.temp
*.log
```